{
  "name": "cymor-business-enterprise",
  "version": "2.0.0",
  "description": "🚀 Elite WhatsApp Business Automation Platform powered by Cymor Enterprise",
  "main": "server.js",

  "scripts": {
    "start": "node server.js",

    "dev": "nodemon server.js",

    "bot": "node src/bot.js",

    "bot:dev": "nodemon src/bot.js",

    "server": "node server.js",

    "clean": "rm -rf node_modules package-lock.json",

    "reinstall": "npm run clean && npm install"
  },

  "keywords": [
    "whatsapp",
    "automation",
    "ai",
    "baileys",
    "firebase",
    "pterodactyl",
    "saas",
    "bot",
    "business",
    "commerce",
    "cymor",
    "enterprise",
    "mpesa",
    "kenya"
  ],

  "author": "Legendary Smiley Cymor",

  "license": "MIT",

  "engines": {
    "node": ">=18.0.0"
  },

  "dependencies": {

    "@whiskeysockets/baileys": "^6.7.18",

    "axios": "^1.8.1",

    "cors": "^2.8.5",

    "dotenv": "^16.4.7",

    "express": "^4.21.2",

    "firebase": "^11.3.1",

    "firebase-admin": "^13.0.2",

    "fs-extra": "^11.3.0",

    "helmet": "^8.0.0",

    "morgan": "^1.10.0",

    "multer": "^1.4.5-lts.1",

    "papaparse": "^5.5.2",

    "pino": "^9.6.0",

    "pino-pretty": "^13.0.0",

    "qrcode": "^1.5.4",

    "socket.io": "^4.8.1",

    "uuid": "^11.1.0"
  },

  "devDependencies": {

    "nodemon": "^3.1.9"
  },

  "nodemonConfig": {

    "ignore": [
      "sessions/*",
      "auth_info/*",
      "node_modules/*"
    ],

    "ext": "js,json",

    "delay": "1000"
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/cymortechservices/cymor-business-enterprise"
  },

  "bugs": {
    "url": "https://github.com/cymortechservices/cymor-business-enterprise/issues"
  },

  "homepage": "https://cymorenterprise.com",

  "funding": {
    "type": "individual",
    "url": "https://cymorenterprise.com"
  }
}
